@{
    ViewData["Title"] = "Đặt xe";
}

<style>
    body {
        background: #f4f6f9;
        font-family: Arial, sans-serif;
    }

    .card {
        max-width: 520px;
        margin: 40px auto;
        background: #fff;
        padding: 25px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

        .card h2 {
            text-align: center;
            margin-bottom: 20px;
        }

    .form-group {
        margin-bottom: 15px;
    }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #ddd;
            border-radius: 10px;
            outline: none;
            font-size: 14px;
            transition: 0.2s;
        }

            .form-group input:focus,
            .form-group textarea:focus {
                border-color: #4a90e2;
                box-shadow: 0 0 0 3px rgba(74,144,226,0.15);
            }

    .car-type {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
    }

        .car-type button {
            flex: 1;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 10px;
            background: #f9f9f9;
            cursor: pointer;
            transition: 0.2s;
            font-size: 14px;
        }

            .car-type button.active {
                background: #4a90e2;
                color: #fff;
                border-color: #4a90e2;
            }

    .price-box {
        margin: 15px 0;
        padding: 12px;
        background: #f1f7ff;
        border-left: 4px solid #4a90e2;
        border-radius: 8px;
        font-weight: bold;
        color: #333;
    }

    .submit-btn {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: #28a745;
        color: #fff;
        font-size: 16px;
        cursor: pointer;
        transition: 0.2s;
    }

        .submit-btn:hover {
            background: #218838;
        }
</style>

<div class="card">
    <h2>🚕 Đặt xe</h2>

    <form method="post">

        <div class="form-group">
            <input name="DiemDon" placeholder="📍 Điểm đón" required />
        </div>

        <div class="form-group">
            <input name="DiemDen" placeholder="🏁 Điểm đến" required />
        </div>

        <div class="car-type">
            <button type="button" class="active" onclick="chonXe(this, 'Car')">🚗 Ô tô</button>
            <button type="button" onclick="chonXe(this, 'Bike')">🏍 Xe máy</button>
        </div>

        <input type="hidden" name="loaiXe" id="loaiXe" value="Car" />

        <div class="form-group">
            <input type="datetime-local" name="ThoiGianDat" />
        </div>

        <div class="form-group">
            <textarea name="GhiChu" rows="3" placeholder="📝 Ghi chú"></textarea>
        </div>

        <input type="hidden" name="km" id="km" />

        <div id="gia" class="price-box">
            💡 Nhập điểm đón + điểm đến để xem giá
        </div>

        <button type="submit" class="submit-btn">🚀 Đặt xe ngay</button>
    </form>
</div>

<script>
    // ===================== CHỌN XE =====================
    function chonXe(btn, loai) {
        document.querySelectorAll('.car-type button').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById("loaiXe").value = loai;
    }

    // ===================== DATA CỐ ĐỊNH =====================
    const diaChiCoSan = {
        "ictu": { lat: 21.5942, lng: 105.8481 },
        "đại học công nghệ thông tin và truyền thông": { lat: 21.5942, lng: 105.8481 },
        "đại học thái nguyên": { lat: 21.5905, lng: 105.8440 },
        "song cong": { lat: 21.47, lng: 105.83 },
        "sông công": { lat: 21.47, lng: 105.83 },
        "ha noi": { lat: 21.0285, lng: 105.8542 },
        "hà nội": { lat: 21.0285, lng: 105.8542 }
    };

    // ===================== CHUẨN HOÁ =====================
    function chuanHoa(diaChi) {
        return diaChi
            .toLowerCase()
            .trim();
    }

    // ===================== LẤY TOẠ ĐỘ =====================
    async function layToaDo(diaChi) {

        const key = chuanHoa(diaChi);

        // 🔥 ưu tiên dữ liệu có sẵn
        if (diaChiCoSan[key]) {
            return diaChiCoSan[key];
        }

        // 🔥 fallback API
        const url = `https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(diaChi + ", Vietnam")}`;

        try {
            const res = await fetch(url);
            const data = await res.json();

            if (data.length > 0) {
                return {
                    lat: parseFloat(data[0].lat),
                    lng: parseFloat(data[0].lon)
                };
            }
        } catch (err) {
            console.log("API lỗi:", err);
        }

        return null;
    }

    // ===================== TÍNH KM + GIÁ =====================
    async function tinhKmVaGia() {
        const diemDon = document.querySelector('[name="DiemDon"]').value;
        const diemDen = document.querySelector('[name="DiemDen"]').value;

        if (!diemDon || !diemDen) return;

        const from = await layToaDo(diemDon);
        const to = await layToaDo(diemDen);

        if (!from || !to) {
            document.getElementById("gia").innerText =
                "❌ Không tìm thấy địa chỉ (hãy nhập đơn giản hơn)";
            return;
        }

        const url = `https://router.project-osrm.org/route/v1/driving/${from.lng},${from.lat};${to.lng},${to.lat}?overview=false`;

        try {
            const res = await fetch(url);
            const data = await res.json();

            if (!data.routes || data.routes.length === 0) {
                document.getElementById("gia").innerText = "❌ Không tính được đường đi";
                return;
            }

            const km = data.routes[0].distance / 1000;
            document.getElementById("km").value = km;

            const gia = 10000 + km * 8000;

            document.getElementById("gia").innerText =
                "💰 " + gia.toLocaleString() + " VNĐ  •  " + km.toFixed(2) + " km";

        } catch (err) {
            document.getElementById("gia").innerText = "❌ Lỗi tính toán";
        }
    }

    // ===================== EVENT =====================
    let timer;

    function debounce(func, delay) {
        return function () {
            clearTimeout(timer);
            timer = setTimeout(func, delay);
        }
    }

    document.querySelector('[name="DiemDon"]').addEventListener("input", debounce(tinhKmVaGia, 500));
    document.querySelector('[name="DiemDen"]').addEventListener("input", debounce(tinhKmVaGia, 500));

    document.querySelector("form").addEventListener("submit", async function (e) {
        e.preventDefault();

        await tinhKmVaGia();

        const km = document.getElementById("km").value;

        if (!km || km == 0) {
            alert("❌ Không tính được khoảng cách!");
            return;
        }

        this.submit();
    });
</script>
