@model Baitap2.Models.ChuyenDi
@using Baitap2.Models

<style>
    body {
        background: #f5f7fa;
        font-family: Arial;
    }

    .container {
        max-width: 500px;
        margin: 20px auto;
    }

    .card {
        background: white;
        padding: 15px;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        margin-bottom: 15px;
    }

    .route {
        font-weight: bold;
        font-size: 16px;
    }

    .price {
        color: #2e7d32;
        font-size: 18px;
        font-weight: bold;
        margin-top: 5px;
    }

    .status {
        text-align: center;
        font-size: 18px;
        padding: 10px;
        border-radius: 10px;
        margin-top: 10px;
        background: #e3f2fd;
        font-weight: bold;
    }

    .cancel-btn {
        width: 100%;
        background: #e53935;
        color: white;
        padding: 10px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        margin-top: 10px;
    }

        .cancel-btn:hover {
            background: #c62828;
        }

    #map {
        height: 300px;
        border-radius: 15px;
        overflow: hidden;
    }
</style>

<div class="container">
    <h2 style="text-align:center;">🚕 Theo dõi chuyến</h2>

    @if (Model == null)
    {
        <div class="card">
            <h3 style="text-align:center;">❌ Không có chuyến</h3>
        </div>
    }
    else
    {
        <div class="card">
            <div class="route">
                📍 @Model.DiemDon → 🏁 @Model.DiemDen
            </div>

            <div class="price">
                💰 @Model.GiaDuKien.ToString("N0") VNĐ
            </div>

            <!-- ❌ HỦY -->
            <div id="btnHuy">
                @if (Model.TrangThai == TrangThai.DangTimTaiXe)
                {
                    <form method="post" asp-action="HuyChuyen">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button class="cancel-btn">
                            ❌ Hủy chuyến
                        </button>
                    </form>
                }
            </div>

            <!-- 🔥 TRẠNG THÁI -->
            <div id="tt" class="status"></div>
        </div>

        <div class="card">
            <div id="map"></div>
        </div>
    }
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>
    const id = "@Model?.Id";

    let map, marker;

    if (id) {
        map = L.map('map').setView([21.0285, 105.8542], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png')
            .addTo(map);

        marker = L.marker([21.0285, 105.8542]).addTo(map);
    }

    async function layToaDo(diaChi) {
        const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(diaChi)}`;
        const res = await fetch(url);
        const data = await res.json();

        if (data.length > 0) {
            return {
                lat: parseFloat(data[0].lat),
                lng: parseFloat(data[0].lon)
            };
        }
        return null;
    }

    async function veDuong() {
        if (!id) return;

        const diemDon = await layToaDo("@Model?.DiemDon");
        const diemDen = await layToaDo("@Model?.DiemDen");

        if (!diemDon || !diemDen) return;

        const url = `https://router.project-osrm.org/route/v1/driving/${diemDon.lng},${diemDon.lat};${diemDen.lng},${diemDen.lat}?overview=full&geometries=geojson`;

        const res = await fetch(url);
        const data = await res.json();

        const coords = data.routes[0].geometry.coordinates;
        const latlngs = coords.map(c => [c[1], c[0]]);

        L.polyline(latlngs, { color: "green", weight: 5 }).addTo(map);
        map.fitBounds(latlngs);
    }

    veDuong();

    function updateUI(status) {
        const tt = document.getElementById("tt");

        switch (status) {
            case "DangTimTaiXe":
                tt.innerText = "🔍 Đang tìm tài xế...";
                break;
            case "DaNhan":
                tt.innerText = "🚗 Đã có tài xế";
                break;
            case "DaDen":
                tt.innerText = "📍 Tài xế đã tới";
                break;
            case "DangDi":
                tt.innerText = "🚕 Đang di chuyển";
                break;
            case "HoanThanh":
                tt.innerText = "🏁 Hoàn thành";
                setTimeout(() => {
                    window.location.href = `/DanhGia/Create?rideId=${id}`;
                }, 1000);
                break;
            case "DaHuy":
                tt.innerText = "❌ Chuyến đã bị hủy";
                document.getElementById("btnHuy").innerHTML = "";
                break;
        }
    }

    function renderHuyButton(status) {
        const container = document.getElementById("btnHuy");

        if (!container) return;

        if (status === "DangTimTaiXe") {
            container.innerHTML = `
                <form method="post" action="/Khach/HuyChuyen">
                    <input type="hidden" name="id" value="${id}" />
                    <button class="cancel-btn">
                        ❌ Hủy chuyến
                    </button>
                </form>
            `;
        } else {
            container.innerHTML = "";
        }
    }

    updateUI("@Model?.TrangThai");
    renderHuyButton("@Model?.TrangThai");

    if (id) {
        const conn = new signalR.HubConnectionBuilder()
            .withUrl("/rideHub")
            .build();

        conn.start().then(() => {
            conn.invoke("ThamGiaChuyen", id);
        });

        conn.on("NhanCapNhat", data => {
            updateUI(data.trangThai);
            renderHuyButton(data.trangThai);
        });

        conn.on("CapNhatViTri", (lat, lng) => {
            if (marker) {
                marker.setLatLng([lat, lng]);
                map.setView([lat, lng]);
            }
        });
    }
</script>