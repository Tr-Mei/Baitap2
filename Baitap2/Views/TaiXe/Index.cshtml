@model Baitap2.Models.ChuyenDi   

<style>
    body {
        background: #f5f7fa;
        font-family: Arial;
    }

    .container {
        max-width: 500px;
        margin: 20px auto;
    }

    .card {
        background: white;
        padding: 15px;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        margin-bottom: 15px;
    }

    h2 {
        text-align: center;
    }

    .route {
        font-weight: bold;
        font-size: 16px;
    }

    .status {
        text-align: center;
        padding: 10px;
        border-radius: 10px;
        font-weight: bold;
        margin-top: 10px;
        background: #e3f2fd;
    }

    .actions a {
        display: block;
        text-align: center;
        margin-top: 10px;
        padding: 10px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: bold;
        color: white;
    }

    .btn-nhan {
        background: #28a745;
    }

    .btn-den {
        background: #17a2b8;
    }

    .btn-batdau {
        background: #ffc107;
        color: black;
    }

    .btn-hoanthanh {
        background: #007bff;
    }

    #map {
        height: 300px;
        border-radius: 15px;
        overflow: hidden;
    }

    .btn-tuchoi {
        background: #dc3545;
    }

</style>

<div class="container">
    <h2>🚗 Tài xế</h2>

    @if (Model == null)
    {
        <div class="card">
            <h3>👋 Xin chào @Context.Session.GetString("Ten")</h3>
            <p style="text-align:center;">🚫 Chưa có cuốc nào</p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="route">
                📍 @Model.DiemDon → 🏁 @Model.DiemDen
            </div>

            <div id="tt" class="status"></div>

            <div id="actions" class="actions"></div>
        </div>

        <div class="card">
            <div id="map"></div>
        </div>
    }
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>


<script>
    const id = @(Model?.Id ?? 0);

    let map, marker;
    let conn;
    let gpsRunning = false;
    let watchId = null;

    // ================= MAP =================
    if (id > 0) {
        map = L.map('map').setView([21.0285, 105.8542], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png')
            .addTo(map);

        marker = L.marker([21.0285, 105.8542]).addTo(map);

        // 📍 Lấy vị trí thật
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(pos => {
                const lat = pos.coords.latitude;
                const lng = pos.coords.longitude;

                map.setView([lat, lng], 15);
                marker.setLatLng([lat, lng]);
            });
        }
    }

    // ================= GPS =================
    function runGPS() {
        if (gpsRunning) return;
        gpsRunning = true;

        if (!navigator.geolocation) {
            alert("❌ Trình duyệt không hỗ trợ GPS");
            return;
        }

        let lastSend = 0;

        watchId = navigator.geolocation.watchPosition(
            pos => {
                const now = Date.now();
                if (now - lastSend < 2000) return; // gửi mỗi 2s

                lastSend = now;

                const lat = pos.coords.latitude;
                const lng = pos.coords.longitude;

                // update map
                if (marker) {
                    marker.setLatLng([lat, lng]);
                    map.setView([lat, lng]);
                }

                // gửi lên server
                if (conn && conn.state === "Connected") {
                    conn.invoke("GuiViTri", id, lat, lng);
                }
            },
            err => {
                console.log("Lỗi GPS:", err.message);

                if (err.code === 1) {
                    alert("❌ Bạn chưa cấp quyền GPS");
                }
            },
            {
                enableHighAccuracy: true,
                maximumAge: 0,
                timeout: 5000
            }
        );
    }

    // ================= UI =================
    function updateUI(status) {
        const tt = document.getElementById("tt");
        const actions = document.getElementById("actions");

        if (!tt || !actions) return;

        actions.innerHTML = "";

        switch (status) {

            case "DangTimTaiXe":
                tt.innerText = "🕐 Có cuốc mới";
                actions.innerHTML = `
                    <a class="btn-nhan" href="/TaiXe/Nhan/${id}">Nhận cuốc</a>
                    <a class="btn-tuchoi" href="/TaiXe/TuChoi/${id}">Từ chối</a>
                `;
                break;

            case "DaNhan":
                tt.innerText = "🚗 Đã nhận cuốc";
                actions.innerHTML = `<a class="btn-den" href="/TaiXe/Den/${id}">Đã tới điểm đón</a>`;
                break;

            case "DaDen":
                tt.innerText = "📍 Đã tới điểm đón";
                actions.innerHTML = `<a class="btn-batdau" href="/TaiXe/BatDau/${id}">Bắt đầu chuyến</a>`;
                break;

            case "DangDi":
                tt.innerText = "🚕 Đang chở khách";

                // 🔥 QUAN TRỌNG: chạy GPS ở đây
                runGPS();

                actions.innerHTML = `<a class="btn-hoanthanh" href="/TaiXe/HoanThanh/${id}">Hoàn thành</a>`;
                break;

            case "HoanThanh":
                tt.innerText = "🏁 Hoàn thành";
                setTimeout(() => location.reload(), 2000);
                break;

            case "DaHuy":
                tt.innerText = "❌ Khách đã hủy";

                if (map) map.remove();

                setTimeout(() => location.reload(), 2000);
                break;
        }
    }

    // ================= SIGNALR =================
    if (id > 0) {
        conn = new signalR.HubConnectionBuilder()
            .withUrl("/rideHub")
            .withAutomaticReconnect() // 🔥 auto reconnect
            .build();

        conn.start().then(() => {
            conn.invoke("ThamGiaChuyen", id);
        });

        conn.on("NhanCapNhat", data => {
            updateUI(data.trangThai);
        });

        // fallback nếu chết hẳn
        let fail = 0;
        conn.onclose(() => {
            fail++;
            if (fail >= 3) {
                location.reload();
            } else {
                setTimeout(() => conn.start(), 2000);
            }
        });
    }

    // ================= INIT =================
    updateUI("@(Model?.TrangThai.ToString() ?? "")");

    // ================= AUTO RELOAD =================
    if (id === 0) {
        setInterval(() => {
            location.reload();
        }, 3000);
    }
</script>
 