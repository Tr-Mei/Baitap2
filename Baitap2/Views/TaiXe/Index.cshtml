@model Baitap2.Models.ChuyenDi

<style>
    body {
        background: #f5f7fa;
        font-family: Arial;
    }

    .container {
        max-width: 500px;
        margin: 20px auto;
    }

    .card {
        background: white;
        padding: 15px;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        margin-bottom: 15px;
    }

    h2 {
        text-align: center;
    }

    .route {
        font-weight: bold;
        font-size: 16px;
    }

    .status {
        text-align: center;
        padding: 10px;
        border-radius: 10px;
        font-weight: bold;
        margin-top: 10px;
        background: #e3f2fd;
    }

    .actions a {
        display: block;
        text-align: center;
        margin-top: 10px;
        padding: 10px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: bold;
        color: white;
    }

    .btn-nhan {
        background: #28a745;
    }

    .btn-den {
        background: #17a2b8;
    }

    .btn-batdau {
        background: #ffc107;
        color: black;
    }

    .btn-hoanthanh {
        background: #007bff;
    }

    #map {
        height: 300px;
        border-radius: 15px;
        overflow: hidden;
    }
</style>

<div class="container">
    <h2>🚗 Tài xế</h2>

    @if (Model == null)
    {
        <div class="card">
            <h3>👋 Xin chào @Context.Session.GetString("Ten")</h3>
            <p style="text-align:center;">🚫 Chưa có cuốc nào</p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="route">
                📍 @Model.DiemDon → 🏁 @Model.DiemDen
            </div>

            <div id="tt" class="status"></div>

            <div id="actions" class="actions"></div>
        </div>

        <div class="card">
            <div id="map"></div>
        </div>
    }
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<script>
    const id = @(Model?.Id ?? 0);

    let map, marker;
    let conn;
    let gpsRunning = false;

    if (id > 0) {
        map = L.map('map').setView([21.0285, 105.8542], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png')
            .addTo(map);

        marker = L.marker([21.0285, 105.8542]).addTo(map);
    }

    function runGPS() {
        if (gpsRunning) return;
        gpsRunning = true;

        let lastSend = 0;

        if (navigator.geolocation) {
            navigator.geolocation.watchPosition(
                pos => {
                    const now = Date.now();
                    if (now - lastSend < 2000) return;

                    lastSend = now;

                    const lat = pos.coords.latitude;
                    const lng = pos.coords.longitude;

                    if (marker) {
                        marker.setLatLng([lat, lng]);
                        map.setView([lat, lng]);
                    }

                    if (conn && conn.state === "Connected") {
                        conn.invoke("GuiViTri", id, lat, lng);
                    }
                },
                err => {
                    alert("❌ Không lấy được GPS");
                }
            );
        }
    }

    function updateUI(status) {
        const tt = document.getElementById("tt");
        const actions = document.getElementById("actions");

        if (!tt || !actions) return;

        actions.innerHTML = "";

        switch (status) {
            case "DangTimTaiXe":
                tt.innerText = "🕐 Có cuốc mới";
                actions.innerHTML = `<a class="btn-nhan" href="/TaiXe/Nhan/${id}">Nhận cuốc</a>`;
                break;

            case "DaNhan":
                tt.innerText = "🚗 Đã nhận cuốc";
                actions.innerHTML = `<a class="btn-den" href="/TaiXe/Den/${id}">Đã tới điểm đón</a>`;
                break;

            case "DaDen":
                tt.innerText = "📍 Đã tới điểm đón";
                actions.innerHTML = `<a class="btn-batdau" href="/TaiXe/BatDau/${id}">Bắt đầu chuyến</a>`;
                break;

            case "DangDi":
                tt.innerText = "🚕 Đang chở khách";
                runGPS();
                actions.innerHTML = `<a class="btn-hoanthanh" href="/TaiXe/HoanThanh/${id}">Hoàn thành</a>`;
                break;

            case "HoanThanh":
                tt.innerText = "🏁 Hoàn thành";
                break;

            case "DaHuy":
                tt.innerText = "❌ Khách đã hủy";

                if (map) {
                    map.remove();
                }

                setTimeout(() => {
                    location.reload();
                }, 2000);
                break;
        }
    }

    if (id > 0) {
        conn = new signalR.HubConnectionBuilder()
            .withUrl("/rideHub")
            .build();

        conn.start().then(() => {
            conn.invoke("ThamGiaChuyen", id);
        });

        conn.on("NhanCapNhat", data => {
            if (data.trangThai === "DaHuy") {
                updateUI("DaHuy");
                return;
            }
            updateUI(data.trangThai);
        });
    }

    updateUI("@(Model?.TrangThai.ToString() ?? "")");
        if (id === 0) {
        setInterval(() => {
            location.reload();
        }, 3000);
    }
</script>


