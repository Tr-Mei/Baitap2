@model int

<h2 style="text-align:center;">⭐ Đánh giá tài xế</h2>

<div style="display:flex; justify-content:center; margin-top:30px;">
    <form method="post"
          style="width:400px; padding:25px; border:1px solid #ccc; border-radius:10px; box-shadow:0 0 10px #ddd;">

        <input type="hidden" name="ChuyenDiId" value="@Model" />

        <!-- ⭐ SỐ SAO -->
        <div style="margin-bottom:20px;">
            <label>Chọn số sao</label>
            <select name="SoSao"
                    style="width:100%; padding:8px; border-radius:5px; border:1px solid #ccc;">
                <option>1 ⭐</option>
                <option>2 ⭐⭐</option>
                <option>3 ⭐⭐⭐</option>
                <option>4 ⭐⭐⭐⭐</option>
                <option selected>5 ⭐⭐⭐⭐⭐</option>
            </select>
        </div>

        <!-- 📝 NHẬN XÉT -->
        <div style="margin-bottom:20px;">
            <label>Nhận xét</label>
            <textarea name="NoiDung" placeholder="Viết nhận xét..."
                      style="width:100%; height:100px; padding:8px; border-radius:5px; border:1px solid #ccc;"></textarea>
        </div>

        <!-- BUTTON -->
        <button type="submit"
                style="width:100%; padding:10px; background:#ffc107; color:black; border:none; border-radius:5px;">
            Gửi đánh giá
        </button>

    </form>
</div>
