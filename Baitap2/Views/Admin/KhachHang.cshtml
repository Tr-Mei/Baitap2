@model List<Baitap2.Models.NguoiDung>
@{
    Layout = null;
}

<h3>👤 Khách hàng</h3>

<table border="1">
    <tr>
        <th>ID</th>
        <th>Username</th>
        <th>Trạng thái</th>
        <th>Hành động</th>
    </tr>

    @foreach (var u in Model)
    {
        <tr>
            <td>@u.Id</td>
            <td>@u.Username</td>
            <td>@(u.IsActive ? "Hoạt động" : "Bị khóa")</td>
            <td>
                <a href="/Admin/ChiTiet/@u.Id">Xem</a> |
                <a href="/Admin/Sua/@u.Id">Sửa</a> |
                <a href="/Admin/Xoa/@u.Id">Xóa</a> |

                @if (u.IsActive)
                {
                    <a href="/Admin/Khoa/@u.Id">Khóa</a>
                }
                else
                {
                    <a href="/Admin/MoKhoa/@u.Id">Mở</a>
                }
            </td>
        </tr>
    }
</table>
