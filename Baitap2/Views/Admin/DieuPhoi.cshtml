<h2>Điều phối tài xế</h2>

<form method="post">
    <input type="hidden" name="chuyenId" value="@Model.Id" />

    <select name="taiXeId">
        @foreach (var tx in ViewBag.TaiXes)
        {
            <option value="@tx.Id">Tài xế @tx.Id</option>
        }
    </select>

    <button>Phân công</button>
</form>

