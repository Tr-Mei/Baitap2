@model Baitap2.Models.NguoiDung
@{
    Layout = null;
}

<style>
    body {
        background: #f4f6f9;
        font-family: Arial;
    }

    .card {
        max-width: 450px;
        margin: 30px auto;
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }

    h3 {
        text-align: center;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        font-weight: bold;
        display: block;
        margin-bottom: 5px;
    }

    input {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid #ccc;
        outline: none;
        transition: 0.2s;
    }

        input:focus {
            border-color: #007bff;
            box-shadow: 0 0 5px rgba(0,123,255,0.3);
        }

    .actions {
        margin-top: 20px;
    }

    button {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        font-weight: bold;
        cursor: pointer;
        background: #007bff;
        color: white;
    }

        button:hover {
            background: #0056b3;
        }

    .back {
        margin-top: 10px;
        display: block;
        text-align: center;
        text-decoration: none;
        color: #555;
    }
</style>

<div class="card">
    <h3>✏️ Sửa người dùng</h3>

    <form method="post">

        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label>👤 Username</label>
            <input asp-for="Username" />
        </div>

        <div class="form-group">
            <label>📧 Email</label>
            <input asp-for="Email" type="email" />
        </div>

        <div class="form-group">
            <label>📱 Điện thoại</label>
            <input asp-for="DienThoai" />
        </div>

        <div class="form-group">
            <label>🔒 Mật khẩu</label>
            <input asp-for="MatKhau" type="password" />
        </div>

        <div class="actions">
            <button type="submit">💾 Lưu thay đổi</button>
        </div>

    </form>

    <a href="/Admin/KhachHang" class="back">⬅️ Quay lại</a>
</div>